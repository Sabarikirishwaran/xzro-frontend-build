# Server-only values. Never prefix these with NEXT_PUBLIC_.
XZRO_BACKEND_URL=https://your-service.example.com
XZRO_BACKEND_API_KEY=replace-with-a-private-service-key

UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-an-upstash-rest-token
# Vercel KV aliases KV_REST_API_URL and KV_REST_API_TOKEN are also accepted.

# Required server-only session signing secret. Use at least 24 random characters.
FRONTEND_DEMO_KEY=replace-with-a-long-random-session-secret
